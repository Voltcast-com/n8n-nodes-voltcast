{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2019",
    "lib": [
      "es2019",
      "es2020"
    ],
    "declaration": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/",
    "useUnknownInCatchVariables": false
  },
  "include": [
    "credentials/**/*",
    "nodes/**/*"
  ]
}