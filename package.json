{
  "name": "@voltcast/n8n-nodes-voltcast",
  "version": "0.1.4",
  "description": "n8n community node for Voltcast \u2014 European electricity prices, forecasts, carbon intensity and optimization",
  "keywords": [
    "n8n-community-node-package",
    "energy",
    "electricity",
    "prices",
    "entso-e",
    "voltcast"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Voltcast-com/n8n-nodes-voltcast",
  "author": {
    "name": "Voltcast",
    "email": "hello@voltcast.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Voltcast-com/n8n-nodes-voltcast.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/VoltcastApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Voltcast/Voltcast.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && mkdir -p dist/nodes/Voltcast && cp nodes/Voltcast/voltcast.svg dist/nodes/Voltcast/",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "n8n-workflow": "^1.70.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "bugs": {
    "url": "https://github.com/Voltcast-com/n8n-nodes-voltcast/issues"
  }
}